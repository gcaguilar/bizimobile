    <string name="changelogWhatsNew">What's new</string>
    <string name="changelogNewCitiesTitle">New cities</string>
    <string name="changelogNewCitiesDescription">Added 14 cities: Bilbao, Bizkaia, León, Valladolid, Málaga, Palma, Las Palmas, A Coruña, Mislata, Rivas-Vaciamadrid, Donostia, Reus, Santander, and Barcelona Donkey.</string>
    <string name="changelogFilterColorsTitle">Filter colors</string>
    <string name="changelogFilterColorsDescription">Each map filter now has a unique color for better visibility.</string>
    <string name="changelogDistanceKmTitle">Distances in kilometers</string>
    <string name="changelogDistanceKmDescription">Distances over 1000m now show in km. New radius options: 1.5km, 2km, 3km, and 5km.</string>
    <string name="changelogDarkModeFixesTitle">Dark mode fixes</string>
    <string name="changelogDarkModeFixesDescription">Fixed colors for search fields and empty cards in dark mode.</string>
    <string name="changelogDarkThemeTitle">Dark theme</string>
    <string name="changelogDarkThemeDescription">The app now adapts automatically to the system dark mode.</string>
    <string name="changelogDismissibleCardTitle">Dismissible card</string>
    <string name="changelogDismissibleCardDescription">You can now close the station card on the map with the X button.</string>
    <string name="changelogMapFiltersTitle">Map filters</string>
    <string name="changelogMapFiltersDescription">Filter stations by availability: bikes + slots, bikes only, or slots only.</string>
    <string name="changelogRefreshIndicatorTitle">Refresh indicator</string>
    <string name="changelogRefreshIndicatorDescription">Visible countdown next to the refresh button (updates every 5 min).</string>
    <string name="changelogMoreCitiesTitle">More Spanish cities</string>
    <string name="changelogMoreCitiesDescription">Added over 35 new cities with public bike sharing. Now available in more than 50 cities across Spain.</string>
    <string name="changelogCitySelectionFixTitle">City selection fixed</string>
    <string name="changelogCitySelectionFixDescription">Changing city during onboarding or in settings now loads stations correctly.</string>
    <string name="changelogBrandRefreshTitle">Fresh visual identity</string>
    <string name="changelogBrandRefreshDescription">Updated colors and surfaces so maps, cards, and status states are easier to read.</string>
    <string name="changelogWatchRefreshTitle">Better Wear OS and Apple Watch apps</string>
    <string name="changelogWatchRefreshDescription">Watch apps now have a clearer interface, highlighted metrics, and quicker actions for your stations.</string>
    <string name="changelogStationLookupFixTitle">More reliable station lookup</string>
    <string name="changelogStationLookupFixDescription">Fixed station-number search so it also works when you type leading zeros.</string>
    <string name="changelogUiImprovementsTitle">UI improvements</string>
    <string name="changelogUiImprovementsDescription">Refined screens, cards, and status states so everyday navigation feels clearer and smoother.</string>
    <string name="changelogPerformanceImprovementsTitle">Performance improvements</string>
    <string name="changelogPerformanceImprovementsDescription">Reduced waiting times and improved overall responsiveness when loading stations and moving around the app.</string>
    <string name="changelogLocalCacheTitle">Smarter local cache</string>
    <string name="changelogLocalCacheDescription">Station data is now cached temporarily on your device to reduce network usage and open faster.</string>
    <string name="changelogDataSourcesTitle">More public bike networks</string>
    <string name="changelogDataSourcesDescription">Added new public data sources and more supported bike sharing systems.</string>
    <string name="changelogSavedPlaceAlertsTitle">Alerts for Home, Work, and favorites</string>
    <string name="changelogSavedPlaceAlertsDescription">Set local notifications when bikes or docks match a condition you pick. Manage from Favorites, station detail, and Profile; open with biciradar://alerts.</string>

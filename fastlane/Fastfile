default_platform(:ios)

def required_env(name)
  value = ENV[name].to_s.strip
  UI.user_error!("Missing required environment variable #{name}") if value.empty?
  value
end

def optional_env(name)
  ENV[name].to_s.strip
end

def required_boolean_env(name)
  value = required_env(name).downcase
  return true if %w[1 true yes y].include?(value)
  return false if %w[0 false no n].include?(value)

  UI.user_error!("Environment variable #{name} must be true/false")
end

platform :ios do
  desc "Build signed IPA for testing (no upload)"
  lane :build_signed_ipa do
    setup_ci

    import_certificate(
      certificate_path: required_env("APPLE_CERTIFICATE_PATH"),
      certificate_password: required_env("APPLE_SIGNING_CERTIFICATE_PASSWORD"),
      keychain_name: "fastlane_tmp_keychain"
    )

    profile_path = required_env("APPLE_PROFILE_PATH")
    profile_name = required_env("APPLE_PROFILE_NAME")
    bundle_id = ENV.fetch("APPLE_BUNDLE_ID", "com.gcaguilar.biciradar.ios")
    team_id = required_env("APPLE_TEAM_ID")

    install_provisioning_profile(path: profile_path)

    build_app(
      project: "apple/BiciRadar.xcodeproj",
      scheme: "BiciRadar",
      configuration: "Release",
      export_method: "app-store",
      destination: "generic/platform=iOS",
      xcargs: "DEVELOPMENT_TEAM='#{team_id}'",
      output_directory: "fastlane/output",
      output_name: "BiciRadar.ipa",
      export_options: {
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: {
          bundle_id => profile_name
        }
      }
    )
  end

  desc "Build signed IPA and upload to App Store Connect for review"
  lane :release_to_app_store do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: required_env("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: required_env("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: required_env("APP_STORE_CONNECT_API_KEY_P8")
    )

    import_certificate(
      certificate_path: required_env("APPLE_CERTIFICATE_PATH"),
      certificate_password: required_env("APPLE_SIGNING_CERTIFICATE_PASSWORD"),
      keychain_name: "fastlane_tmp_keychain"
    )

    profile_path = required_env("APPLE_PROFILE_PATH")
    profile_name = required_env("APPLE_PROFILE_NAME")
    bundle_id = ENV.fetch("APPLE_BUNDLE_ID", "com.gcaguilar.biciradar.ios")
    team_id = required_env("APPLE_TEAM_ID")

    install_provisioning_profile(path: profile_path)

    build_app(
      project: "apple/BiciRadar.xcodeproj",
      scheme: "BiciRadar",
      configuration: "Release",
      export_method: "app-store",
      destination: "generic/platform=iOS",
      xcargs: "DEVELOPMENT_TEAM='#{team_id}'",
      output_directory: "fastlane/output",
      output_name: "BiciRadar.ipa",
      export_options: {
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: {
          bundle_id => profile_name
        }
      }
    )

    upload_to_app_store(
      api_key: api_key,
      platform: "ios",
      app_identifier: ENV.fetch("APPLE_BUNDLE_ID", "com.gcaguilar.biciradar.ios"),
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH],
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      run_precheck_before_submit: true,
      submission_information: {
        export_compliance_uses_encryption: required_boolean_env("APP_USES_ENCRYPTION")
      },
      app_review_information: {
        first_name: required_env("APP_REVIEW_CONTACT_FIRST_NAME"),
        last_name: required_env("APP_REVIEW_CONTACT_LAST_NAME"),
        phone_number: required_env("APP_REVIEW_CONTACT_PHONE"),
        email_address: required_env("APP_REVIEW_CONTACT_EMAIL"),
        notes: optional_env("APP_REVIEW_NOTES")
      }
    )
  end
end

default_platform(:ios)

def required_env(name)
  value = ENV[name].to_s.strip
  UI.user_error!("Missing required environment variable #{name}") if value.empty?
  value
end

def optional_env(name)
  ENV[name].to_s.strip
end

def required_boolean_env(name)
  value = required_env(name).downcase
  return true if %w[1 true yes y].include?(value)
  return false if %w[0 false no n].include?(value)

  UI.user_error!("Environment variable #{name} must be true/false")
end

  platform :ios do
  desc "Build signed IPA for testing (no upload)"
  lane :build_signed_ipa do
    setup_ci

    import_certificate(
      certificate_path: required_env("APPLE_CERTIFICATE_PATH"),
      certificate_password: required_env("APPLE_SIGNING_CERTIFICATE_PASSWORD"),
      keychain_name: "fastlane_tmp_keychain"
    )

    profile_path = required_env("APPLE_PROFILE_PATH")
    profile_name = ENV.fetch("APPLE_PROFILE_NAME", nil)&.strip
    bundle_id = ENV.fetch("APPLE_BUNDLE_ID", "com.gcaguilar.biciradar.ios")&.strip
    team_id = required_env("APPLE_TEAM_ID")&.strip

    install_provisioning_profile(path: profile_path)

    xcargs = "DEVELOPMENT_TEAM='#{team_id}' CODE_SIGN_STYLE=Manual"
    if profile_name
      profile_name_clean = profile_name.strip
      xcargs += " PROVISIONING_PROFILE_SPECIFIER='#{profile_name_clean}'"
    end

    build_app(
      project: "apple/BiciRadar.xcodeproj",
      scheme: "BiciRadar",
      configuration: "Release",
      export_method: "app-store",
      destination: "generic/platform=iOS",
      xcargs: xcargs,
      output_directory: "fastlane/output",
      output_name: "BiciRadar.ipa",
      export_options: {
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: profile_name ? { bundle_id.strip => profile_name.strip } : nil
      }.compact
    )
  end

  desc "Build signed IPA and upload to App Store Connect for review"
  lane :release_to_app_store do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: required_env("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: required_env("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: required_env("APP_STORE_CONNECT_API_KEY_P8"),
      is_key_content_base64: true
    )

    import_certificate(
      certificate_path: required_env("APPLE_CERTIFICATE_PATH"),
      certificate_password: required_env("APPLE_SIGNING_CERTIFICATE_PASSWORD"),
      keychain_name: "fastlane_tmp_keychain"
    )

    profile_path = required_env("APPLE_PROFILE_PATH")
    profile_name = ENV.fetch("APPLE_PROFILE_NAME", nil)&.strip
    bundle_id = ENV.fetch("APPLE_BUNDLE_ID", "com.gcaguilar.biciradar.ios")&.strip
    team_id = required_env("APPLE_TEAM_ID")&.strip
    watch_profile_path = ENV.fetch("APPLE_WATCH_PROFILE_PATH", nil)&.strip
    watch_profile_name = ENV.fetch("APPLE_WATCH_PROFILE_NAME", nil)&.strip

    install_provisioning_profile(path: profile_path)
    install_provisioning_profile(path: watch_profile_path) if watch_profile_path

    xcargs = "DEVELOPMENT_TEAM='#{team_id}' CODE_SIGN_STYLE=Manual"

    provisioning_profiles = {}
    provisioning_profiles[bundle_id] = profile_name if profile_name
    provisioning_profiles["com.gcaguilar.biciradar.ios.watch"] = watch_profile_name if watch_profile_name

    build_app(
      project: "apple/BiciRadar.xcodeproj",
      scheme: "BiciRadar",
      configuration: "Release",
      export_method: "app-store",
      destination: "generic/platform=iOS",
      xcargs: xcargs,
      output_directory: "fastlane/output",
      output_name: "BiciRadar.ipa",
      export_options: {
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: provisioning_profiles.empty? ? nil : provisioning_profiles
      }.compact
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: bundle_id,
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH],
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end

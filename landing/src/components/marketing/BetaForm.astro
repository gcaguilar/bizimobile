---
import type { HomeContent, Locale } from '../../content/marketing/types';
import { appStoreUrlForLocale, playStoreUrlForLocale } from '../../lib/site-config';

interface Props {
  locale: Locale;
  content: HomeContent['betaForm'];
}

const { locale, content } = Astro.props;
const appStoreHref = appStoreUrlForLocale(locale);
const playStoreHref = playStoreUrlForLocale(locale);

const storeLabels: Record<Locale, { ios: string; android: string; note: string }> = {
  es: {
    ios: 'Descargar en App Store',
    android: 'Descargar en Google Play',
    note: 'Instala BiciRadar directamente desde tu tienda.',
  },
  en: {
    ios: 'Download on the App Store',
    android: 'Get it on Google Play',
    note: 'Install BiciRadar directly from your store.',
  },
  ca: {
    ios: 'Descarrega a l’App Store',
    android: 'Descarrega a Google Play',
    note: 'Instal·la BiciRadar directament des de la teva botiga.',
  },
  gl: {
    ios: 'Descargar na App Store',
    android: 'Descargar en Google Play',
    note: 'Instala BiciRadar directamente desde a túa tenda.',
  },
  eu: {
    ios: 'Deskargatu App Storen',
    android: 'Deskargatu Google Play-n',
    note: 'Instalatu BiciRadar zuzenean zure dendatik.',
  },
};

const labels = storeLabels[locale];
---

<section class="marketing-form-card" id="beta-form" aria-labelledby="beta-form-title">
  <div class="space-y-3">
    <h2 class="text-3xl font-bold tracking-tight text-emerald-950" id="beta-form-title">
      {content.title}
    </h2>
    <p class="max-w-3xl text-sm leading-6 text-emerald-900/80">
      {content.description}
    </p>
  </div>

  <div class="mt-8 grid gap-4 md:grid-cols-2">
    <a
      class="marketing-platform-card marketing-platform-card-ios"
      href={appStoreHref}
      target="_blank"
      rel="noreferrer"
      data-track-event="store_download_click"
      data-track-store="app_store"
      data-track-placement="download_section"
    >
      <span class="marketing-chip marketing-chip-primary">iPhone</span>
      <span class="marketing-platform-card__button marketing-platform-card__button-ios">
        {labels.ios}
      </span>
    </a>

    <a
      class="marketing-platform-card marketing-platform-card-android"
      href={playStoreHref}
      target="_blank"
      rel="noreferrer"
      data-track-event="store_download_click"
      data-track-store="play_store"
      data-track-placement="download_section"
    >
      <span class="marketing-chip marketing-chip-secondary">Android</span>
      <span class="marketing-platform-card__button marketing-platform-card__button-android">
        {labels.android}
      </span>
    </a>
  </div>

  <p class="mt-4 text-sm leading-6 text-slate-600">{labels.note}</p>
</section>

---
import type { CityKey, HomeContent, Locale } from '../../content/marketing/types';

interface Props {
  locale: Locale;
  content: HomeContent['betaForm'];
  pageKind: 'home' | 'city';
  pagePath: string;
  thankYouPath: string;
  cityPageKey?: CityKey;
}

const { locale, content, pageKind, pagePath, thankYouPath, cityPageKey = '' } = Astro.props;

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY?.trim() ?? '';

const betaFormMessages = {
  required: content.validation.required,
  email: content.validation.email,
  consent: content.validation.consent,
  turnstile: content.validation.turnstile,
  server: content.validation.server,
  loading: content.loadingLabel,
  success: content.successMessage,
  submit: content.submitLabel,
};
---

<section class="marketing-form-card" id="beta-form" aria-labelledby="beta-form-title">
  <div class="space-y-3">
    <h2 class="text-3xl font-bold tracking-tight text-emerald-950" id="beta-form-title">
      {content.title}
    </h2>
    <p class="max-w-3xl text-sm leading-6 text-emerald-900/80">
      {content.description}
    </p>
    <p class="text-sm text-emerald-900/70">{content.helper}</p>
  </div>

  <form
    action="/api/beta-signup"
    class="mt-8 space-y-5"
    data-beta-form
    data-error-message={content.errorMessage}
    data-page-kind={pageKind}
    data-city-page-key={cityPageKey}
    data-page-path={pagePath}
    data-redirect-path={thankYouPath}
    data-turnstile-active={turnstileSiteKey ? 'true' : 'false'}
  >
    <div class="grid gap-4 md:grid-cols-2">
      <label class="marketing-field">
        <span>{content.fields.email.label}</span>
        <input
          name="email"
          type="email"
          placeholder={content.fields.email.placeholder}
          required
          autocomplete="email"
          inputmode="email"
          maxlength="254"
        />
      </label>

      <label class="marketing-field">
        <span>{content.fields.operatingSystem.label}</span>
        <select name="operatingSystem" required>
          <option value="">{content.fields.operatingSystem.placeholder}</option>
          {content.options.operatingSystems.map((option) => (
            <option value={option.value}>{option.label}</option>
          ))}
        </select>
      </label>

      <label class="marketing-field">
        <span>{content.fields.city.label}</span>
        <select name="city" required>
          <option value="">{content.fields.city.placeholder}</option>
          {content.options.cities.map((option) => (
            <option value={option.value}>{option.label}</option>
          ))}
        </select>
      </label>

      <label class="marketing-field">
        <span>{content.fields.bikeSystem.label}</span>
        <select name="bikeSystem" required>
          <option value="">{content.fields.bikeSystem.placeholder}</option>
          {content.options.systems.map((option) => (
            <option value={option.value}>{option.label}</option>
          ))}
        </select>
      </label>

      <label class="marketing-field">
        <span>{content.fields.frequency.label}</span>
        <select name="frequency" required>
          <option value="">{content.fields.frequency.placeholder}</option>
          {content.options.frequencies.map((option) => (
            <option value={option.value}>{option.label}</option>
          ))}
        </select>
      </label>

      <label class="marketing-field">
        <span>{content.fields.interest.label}</span>
        <select name="interest">
          <option value="">{content.fields.interest.placeholder}</option>
          {content.options.interests.map((option) => (
            <option value={option.value}>{option.label}</option>
          ))}
        </select>
      </label>

      <label class="marketing-field">
        <span>{content.fields.widgets.label}</span>
        <select name="widgets">
          <option value="">{content.fields.widgets.placeholder}</option>
          {content.options.yesNo.map((option) => (
            <option value={option.value}>{option.label}</option>
          ))}
        </select>
      </label>

      <label class="marketing-field">
        <span>{content.fields.smartwatch.label}</span>
        <select name="smartwatch">
          <option value="">{content.fields.smartwatch.placeholder}</option>
          {content.options.yesNo.map((option) => (
            <option value={option.value}>{option.label}</option>
          ))}
        </select>
      </label>
    </div>

    <div id="beta-form-consent" class="space-y-3 rounded-2xl border border-emerald-200 bg-white/70 p-4">
      <label class="flex items-start gap-3 text-sm leading-6 text-slate-700">
        <input
          class="mt-1 size-4 rounded border-slate-300"
          name="consent"
          type="checkbox"
          value="true"
          required
          data-beta-consent
        />
        <span>{content.consentLabel}</span>
      </label>
      <p class="text-xs text-slate-600">{content.consentHint}</p>
    </div>

    {
      turnstileSiteKey ? (
        <div class="rounded-2xl border border-slate-200 bg-white/80 p-4">
          <input type="hidden" name="cf-turnstile-response" value="" data-turnstile-response />
          <div class="min-h-[65px]" data-turnstile-container />
        </div>
      ) : null
    }

    <div class="sr-only">
      <label>
        {content.honeypotLabel}
        <input name="company" type="text" tabindex="-1" autocomplete="off" />
      </label>
    </div>

    <input name="locale" type="hidden" value={locale} />
    <input name="pageKind" type="hidden" value={pageKind} />
    <input name="cityPageKey" type="hidden" value={cityPageKey} />
    <input name="pagePath" type="hidden" value={pagePath} />
    <input name="startedAt" type="hidden" value="" data-started-at />
    <input name="utm_source" type="hidden" value="" data-utm-field="utm_source" />
    <input name="utm_medium" type="hidden" value="" data-utm-field="utm_medium" />
    <input name="utm_campaign" type="hidden" value="" data-utm-field="utm_campaign" />
    <input name="utm_content" type="hidden" value="" data-utm-field="utm_content" />
    <input name="utm_term" type="hidden" value="" data-utm-field="utm_term" />

    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
      <button
        class="marketing-primary-button disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-45"
        type="submit"
        disabled
        data-beta-submit
        aria-describedby="beta-form-consent"
      >
        <span data-submit-label>{content.submitLabel}</span>
      </button>
      <p aria-live="polite" class="text-sm font-medium text-emerald-950" data-form-status></p>
    </div>
  </form>
</section>

<script
  is:inline
  type="application/json"
  data-beta-form-config
  set:html={JSON.stringify({ messages: betaFormMessages, turnstileSiteKey })}
/>
<script>
  import { mountBetaForm } from '../../lib/beta-form-client';
  mountBetaForm();
</script>

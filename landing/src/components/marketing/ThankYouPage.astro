---
import type { CityKey, LocaleContent } from '../../content/marketing/types';
import PageHeader from './PageHeader.astro';
import SiteFooter from './SiteFooter.astro';
import AnalyticsScripts from './AnalyticsScripts.astro';
import { appStoreUrlForLocale, playStoreUrlForLocale, siteConfig } from '../../lib/site-config';
import Icon from '../Icon.astro';

interface LanguageLink {
  href: string;
  label: string;
  localeLabel: string;
  current: boolean;
}

interface CityLink {
  key: CityKey;
  href: string;
  name: string;
  label: string;
}

interface Props {
  content: LocaleContent;
  languageLinks: LanguageLink[];
  homeHref: string;
  betaHref: string;
  cityLinks: CityLink[];
}

const { content, languageLinks, homeHref, betaHref, cityLinks } = Astro.props;

const thankYouCopy = content.thankYou;
const appStoreHref = appStoreUrlForLocale(content.locale);
const playStoreHref = playStoreUrlForLocale(content.locale);
---

<PageHeader
  siteName={content.metadata.siteName}
  homeHref={homeHref}
  languageLabel={content.home.header.languageLabel}
  languageLinks={languageLinks}
  primaryCtaLabel={content.common.backToHome}
  primaryCtaHref={homeHref}
  primaryEvent="city_revisit_click"
  githubAriaLabel={content.common.githubAriaLabel}
/>

<main id="main-content">
  <section class="marketing-shell">
    <div class="marketing-thank-you-card">
      <span class="marketing-chip marketing-chip-success">{thankYouCopy.badge}</span>
      <h1
        class="max-w-4xl text-balance text-4xl font-black tracking-tight text-slate-950 sm:text-5xl"
        data-thank-you-title
      >
        {thankYouCopy.ios.title}
      </h1>
      <p class="max-w-3xl text-lg leading-8 text-slate-600" data-thank-you-description>
        {thankYouCopy.ios.description}
      </p>

      <ol class="space-y-3 text-sm leading-6 text-slate-700" data-thank-you-steps-ios>
        {thankYouCopy.ios.steps.map((step) => (
          <li class="flex gap-3">
            <span class="mt-1 flex size-6 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-xs font-bold text-emerald-700">
              <Icon class="size-3" name="check" />
            </span>
            <span>{step}</span>
          </li>
        ))}
      </ol>

      <ol class="hidden space-y-3 text-sm leading-6 text-slate-700" data-thank-you-steps-android-only>
        {thankYouCopy.androidOrBoth.stepsAndroid.map((step) => (
          <li class="flex gap-3">
            <span class="mt-1 flex size-6 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-xs font-bold text-emerald-700">
              <Icon class="size-3" name="check" />
            </span>
            <span>{step}</span>
          </li>
        ))}
      </ol>

      <ol class="hidden space-y-3 text-sm leading-6 text-slate-700" data-thank-you-steps-both-platforms>
        {thankYouCopy.androidOrBoth.stepsBoth.map((step) => (
          <li class="flex gap-3">
            <span class="mt-1 flex size-6 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-xs font-bold text-emerald-700">
              <Icon class="size-3" name="check" />
            </span>
            <span>{step}</span>
          </li>
        ))}
      </ol>

      <div class="flex flex-col flex-wrap gap-3 sm:flex-row" data-thank-you-actions>
        <a class="marketing-secondary-button" href="#available-cities">
          {thankYouCopy.primaryCta}
        </a>
        <a
          class="marketing-primary-button hidden"
          href={siteConfig.googleTestersGroupUrl}
          target="_blank"
          rel="noreferrer"
          data-thank-you-google-group
          data-track-event="beta_google_group_click"
          data-track-placement="thank_you"
        >
          {thankYouCopy.googleGroupCta}
        </a>
        <a
          class="marketing-primary-button hidden"
          href={playStoreHref}
          target="_blank"
          rel="noreferrer"
          data-thank-you-play-store
          data-track-event="hero_play_store_click"
          data-track-placement="thank_you"
        >
          {thankYouCopy.playStoreCta}
        </a>
        <a
          class="marketing-primary-button"
          href={appStoreHref}
          target="_blank"
          rel="noreferrer"
          data-thank-you-app-store
          data-track-event="hero_secondary_cta_click"
          data-track-placement="thank_you"
        >
          {thankYouCopy.appStoreCta}
        </a>
        <button class="marketing-secondary-button" type="button" data-share-button data-track-event="share_click">
          {thankYouCopy.shareLabel}
        </button>
      </div>
    </div>
  </section>

  <section class="marketing-shell" id="available-cities">
    <div class="space-y-3">
      <h2 class="marketing-section-title">{thankYouCopy.cityLinksTitle}</h2>
      <p class="max-w-3xl text-base leading-7 text-slate-600">{content.common.shareDescription}</p>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {cityLinks.map((city) => (
        <a
          class="marketing-city-card"
          href={city.href}
          data-track-event="city_revisit_click"
          data-track-label={city.label}
        >
          <div class="space-y-2">
            <p class="text-sm font-semibold text-sky-700">{city.label}</p>
            <h3 class="marketing-card-title">{`${thankYouCopy.cityCardCtaPrefix} ${city.name}`}</h3>
          </div>
        </a>
      ))}
    </div>

    <p class="mt-4 text-sm text-slate-500">{thankYouCopy.footnote}</p>
  </section>

  <SiteFooter
    siteName={content.metadata.siteName}
    tagline={content.home.footer.tagline}
    links={content.home.footer.links}
    note={content.home.footer.note}
    betaLabel={content.home.footer.primaryCta}
    betaHref={betaHref}
    languageLabel={content.home.header.languageLabel}
    languageLinks={languageLinks}
    githubLine={content.home.footer.githubLine}
  />
</main>

<script
  is:inline
  define:vars={{
    fallbackMessage: content.common.thankYouShareFallback,
    copyAndroid: thankYouCopy.androidOrBoth,
  }}
>
  (() => {
    const button = document.querySelector('[data-share-button]');
    const titleEl = document.querySelector('[data-thank-you-title]');
    const descriptionEl = document.querySelector('[data-thank-you-description]');
    const stepsIos = document.querySelector('[data-thank-you-steps-ios]');
    const stepsAndroidOnly = document.querySelector('[data-thank-you-steps-android-only]');
    const stepsBothPlatforms = document.querySelector('[data-thank-you-steps-both-platforms]');
    const appStoreLink = document.querySelector('[data-thank-you-app-store]');
    const groupLink = document.querySelector('[data-thank-you-google-group]');
    const playLink = document.querySelector('[data-thank-you-play-store]');
    const searchParams = new URLSearchParams(window.location.search);
    const signupOs = (searchParams.get('os') || '').toLowerCase();
    const isAndroidFlow = signupOs === 'android' || signupOs === 'both';

    if (signupOs === 'android') {
      if (titleEl) titleEl.textContent = copyAndroid.title;
      if (descriptionEl) descriptionEl.textContent = copyAndroid.description;
      stepsIos?.classList.add('hidden');
      stepsAndroidOnly?.classList.remove('hidden');
    } else if (signupOs === 'both') {
      if (titleEl) titleEl.textContent = copyAndroid.title;
      if (descriptionEl) descriptionEl.textContent = copyAndroid.description;
      stepsIos?.classList.add('hidden');
      stepsBothPlatforms?.classList.remove('hidden');
    }

    if (isAndroidFlow) {
      if (appStoreLink instanceof HTMLElement) appStoreLink.classList.add('hidden');
      if (groupLink instanceof HTMLElement) groupLink.classList.remove('hidden');
      if (playLink instanceof HTMLElement) playLink.classList.remove('hidden');
      if (signupOs === 'both' && appStoreLink instanceof HTMLElement) {
        appStoreLink.classList.remove('hidden');
      }
    } else {
      if (groupLink instanceof HTMLElement) groupLink.classList.add('hidden');
      if (playLink instanceof HTMLElement) playLink.classList.add('hidden');
    }

    if (!(button instanceof HTMLButtonElement)) return;

    button.addEventListener('click', async () => {
      const shareData = {
        title: document.title,
        text: document.title,
        url: window.location.origin,
      };

      try {
        if (navigator.share) {
          await navigator.share(shareData);
          return;
        }

        await navigator.clipboard.writeText(window.location.origin);
        alert(fallbackMessage);
      } catch (error) {
        console.error(error);
      }
    });
  })();
</script>

<AnalyticsScripts locale={content.locale} pageKind="thank-you" />

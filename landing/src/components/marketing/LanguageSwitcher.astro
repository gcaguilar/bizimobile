---
interface LinkItem {
  href: string;
  label: string;
  localeLabel: string;
  current: boolean;
}

interface Props {
  label: string;
  links: LinkItem[];
}

const { label, links } = Astro.props;
---

<div class="flex items-center gap-2" aria-label={label}>
  {links.map((link) => (
    <a
      class:list={[
        'rounded-full border px-3 py-1.5 text-xs font-semibold transition',
        link.current
          ? 'border-slate-900 bg-slate-900 text-white'
          : 'border-slate-300 bg-white text-slate-600 hover:border-slate-900 hover:text-slate-900',
      ]}
      href={link.href}
      aria-current={link.current ? 'true' : undefined}
    >
      <span class="sr-only">{link.label}</span>
      {link.localeLabel}
    </a>
  ))}
</div>

---
import LanguageSwitcher from './LanguageSwitcher.astro';
import Icon from '../Icon.astro';
import { siteConfig } from '../../lib/site-config';

interface FooterLink {
  href: string;
  label: string;
}

interface LocaleLink {
  href: string;
  label: string;
  localeLabel: string;
  current: boolean;
}

interface Props {
  siteName: string;
  tagline: string;
  links: FooterLink[];
  note: string;
  betaLabel: string;
  betaHref: string;
  languageLabel: string;
  languageLinks: LocaleLink[];
  githubLine: string;
}

const {
  siteName,
  tagline,
  links,
  note,
  betaLabel,
  betaHref,
  languageLabel,
  languageLinks,
  githubLine,
} = Astro.props;
const currentYear = new Date().getFullYear();
const githubHref = siteConfig.githubUrl;
---

<footer class="border-t border-slate-200 bg-white">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 md:grid-cols-[1.4fr_1fr] md:px-6">
    <div class="space-y-3">
      <div class="text-lg font-black text-slate-950">{siteName}</div>
      <p class="max-w-2xl text-sm leading-6 text-slate-600">{tagline}</p>
      <p class="text-xs text-slate-500">{note}</p>
      <p class="text-xs text-slate-400">© {currentYear} {siteName}</p>
    </div>

    <div class="space-y-5">
      <a
        class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-emerald-600"
        href={betaHref}
        data-track-event="footer_beta_click"
      >
        {betaLabel}
      </a>

      <LanguageSwitcher label={languageLabel} links={languageLinks} />

      <a
        class="inline-flex max-w-full items-center gap-2 text-sm text-slate-600 transition hover:text-slate-950"
        href={githubHref}
        target="_blank"
        rel="noopener noreferrer"
        data-track-event="github_click"
        data-track-placement="footer"
      >
        <Icon name="github" class="size-5 shrink-0" />
        <span class="leading-snug underline-offset-2 hover:underline">{githubLine}</span>
      </a>

      <div class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-slate-600">
        {links.map((link) => (
          <a class="transition hover:text-slate-950 hover:underline" href={link.href}>
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>

---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import {
  citiesByLanguage,
  defaultLanguage,
  faqByLanguage,
  languageHtmlLang,
  languageNames,
  seoPageCtaByLanguage,
  translations,
} from '../data/landing';
import { withBase } from '../utils/paths';
import heroImage from '../assets/landing/hero.jpg';
import featureAvailabilityImage from '../assets/landing/feature-availability.jpg';
import featureFavoritesImage from '../assets/landing/feature-favorites.jpg';
import featureWidgetsImage from '../assets/landing/feature-widgets.jpg';
import mapBackgroundImage from '../assets/landing/map-bg.jpg';

const lang = defaultLanguage;
const t = translations[lang];
const faqItems = faqByLanguage[lang];
const cities = citiesByLanguage[lang];
const currentYear = new Date().getFullYear();
const seoPagePath = withBase('/biciradar-complemento-app-oficial', import.meta.env.BASE_URL);

const landingRuntime = {
  defaultLanguage,
  translations,
  faqByLanguage,
  citiesByLanguage,
  seoPageCtaByLanguage,
  languageHtmlLang,
};
---

<div class="min-h-screen" data-landing-root>
  <header class="fixed top-0 z-50 w-full border-b border-transparent bg-white/80 shadow-sm backdrop-blur-md transition-colors dark:border-white/5 dark:bg-[#121212]/80 dark:shadow-none">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 md:px-8">
      <div class="flex items-center gap-2">
        <span class="font-headline text-2xl font-black tracking-tighter text-blue-800 dark:text-primary">
          BiciRadar
        </span>
      </div>

      <div class="hidden items-center space-x-8 md:flex">
        <a class="font-headline pb-1 text-blue-700 transition-colors hover:text-primary dark:text-on-surface" href="#features" data-i18n="features">
          {t.features}
        </a>
        <a class="font-headline pb-1 text-blue-700 transition-colors hover:text-primary dark:text-on-surface" href="#cities" data-i18n="cities">
          {t.cities}
        </a>
        <a class="font-headline pb-1 text-blue-700 transition-colors hover:text-primary dark:text-on-surface" href="#faqs" data-i18n="faqs">
          {t.faqs}
        </a>
        <a class="font-headline pb-1 text-blue-700 transition-colors hover:text-primary dark:text-on-surface" href="#contact" data-i18n="contact">
          {t.contact}
        </a>
      </div>

      <div class="flex items-center gap-4">
        <button
          aria-label="Cambiar tema"
          class="rounded-lg p-2 transition-colors hover:bg-surface-container"
          data-theme-toggle
          type="button"
        >
          <Icon class="block size-5 dark:hidden" name="moon" />
          <Icon class="hidden size-5 dark:block" name="sun" />
        </button>
        <a
          class="rounded-xl bg-primary px-5 py-2.5 font-bold tracking-tight text-on-primary transition-all duration-200 hover:shadow-lg hover:shadow-primary/20 active:scale-95 md:px-6"
          href="#download"
          data-i18n="downloadApp"
        >
          {t.downloadApp}
        </a>
      </div>
    </nav>
  </header>

  <main class="pt-20">
    <section class="relative mx-auto flex min-h-[860px] max-w-7xl items-center px-6 md:px-8">
      <div class="grid w-full items-center gap-12 lg:grid-cols-2">
        <div class="z-10">
          <h1 class="mb-8 text-5xl font-bold leading-[0.92] tracking-tighter text-on-surface md:text-6xl lg:text-8xl">
            <span class="font-headline" data-i18n="heroTitle">{t.heroTitle}</span>
            {' '}
            <span class="font-headline text-primary" data-i18n="radar">{t.radar}</span>
          </h1>
          <p class="mb-10 max-w-xl text-lg leading-relaxed text-on-surface-variant md:text-xl" data-i18n="heroSubtitle">
            {t.heroSubtitle}
          </p>

          <div class="flex flex-wrap gap-4" id="download">
            <a
              class="flex items-center gap-3 rounded-xl bg-on-surface px-6 py-4 font-bold text-surface-container-lowest transition-all hover:bg-primary active:scale-95 md:px-8"
              data-track-store="app_store"
              href="https://apps.apple.com/es/app/biciradar/id6760931316"
              rel="noopener noreferrer"
              target="_blank"
            >
              <Icon class="size-6 shrink-0" name="phone" />
              <div class="text-left leading-none">
                <p class="text-[10px] uppercase opacity-70" data-i18n="downloadOnThe">{t.downloadOnThe}</p>
                <p class="text-lg" data-i18n="appStore">{t.appStore}</p>
              </div>
            </a>

            <a
              class="flex items-center gap-3 rounded-xl border-2 border-outline-variant/20 bg-surface-container-high px-6 py-4 font-bold text-on-surface transition-all hover:bg-secondary-container dark:hover:bg-secondary active:scale-95 md:px-8"
              data-track-store="android_testers"
              href="https://groups.google.com/g/testers-biciradar"
              rel="noopener noreferrer"
              target="_blank"
            >
              <Icon class="size-6 shrink-0" name="download" />
              <div class="text-left leading-none">
                <p class="text-[10px] uppercase opacity-70">Android</p>
                <p class="text-lg" data-i18n="joinTesters">{t.joinTesters}</p>
              </div>
            </a>

            <a
              class="flex items-center gap-3 rounded-xl border-2 border-outline-variant/20 bg-surface-container-high px-6 py-4 font-bold text-on-surface transition-all hover:bg-secondary-container dark:hover:bg-secondary active:scale-95 md:px-8"
              data-track-store="play_store"
              href="https://play.google.com/store/apps/details?id=com.gcaguilar.biciradar"
              rel="noopener noreferrer"
              target="_blank"
            >
              <Icon class="size-6 shrink-0" name="download" />
              <div class="text-left leading-none">
                <p class="text-[10px] uppercase opacity-70">Android</p>
                <p class="text-lg" data-i18n="downloadAndroidApp">{t.downloadAndroidApp}</p>
              </div>
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="absolute inset-0 -z-10 rounded-full bg-primary/10 blur-[120px] dark:bg-primary/20"></div>
          <div class="relative flex justify-center lg:justify-end">
            <Image
              alt="Pantallas de la app BiciRadar"
              class="w-full max-w-[500px] object-contain drop-shadow-2xl dark:brightness-90 dark:grayscale-[0.2]"
              decoding="async"
              fetchpriority="high"
              format="webp"
              loading="eager"
              quality={80}
              sizes="(min-width: 1024px) 500px, (min-width: 768px) 44vw, 92vw"
              src={heroImage}
              widths={[420, 560, 760, 960]}
            />

            <div class="absolute -left-10 top-1/4 hidden rounded-2xl border border-outline-variant/10 bg-white/90 p-4 shadow-xl backdrop-blur-xl dark:border-white/10 dark:bg-surface-container/90 md:block">
              <div class="flex items-center gap-3">
                <div class="flex size-10 items-center justify-center rounded-full bg-secondary-container">
                  <Icon class="size-5 text-secondary dark:text-white" name="bike" />
                </div>
                <div>
                  <p class="text-xs font-bold text-slate-700 dark:text-slate-300" data-i18n="bicimadAvailable">
                    {t.bicimadAvailable}
                  </p>
                  <p class="font-headline text-lg font-black text-slate-900 dark:text-white">
                    12 <span data-i18n="units">{t.units}</span>
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-24 md:px-8" id="features">
      <div class="mb-16">
        <h2 class="font-headline mb-4 text-4xl font-bold tracking-tight lg:text-5xl" data-i18n="experience">
          {t.experience}
        </h2>
        <div class="h-1.5 w-24 rounded-full bg-secondary-container dark:bg-accent"></div>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-12 md:items-start">
        <article class="group flex flex-col gap-8 overflow-hidden rounded-3xl bg-surface-container p-8 dark:border dark:border-white/5 md:col-span-8 md:flex-row md:items-center md:p-12">
          <div class="min-w-0 flex-1">
            <span class="mb-4 block text-xs font-bold uppercase tracking-widest text-primary" data-i18n="feature1Title">
              {t.feature1Title}
            </span>
            <h3 class="font-headline mb-6 text-3xl font-bold" data-i18n="feature1Title">{t.feature1Title}</h3>
            <p class="mb-8 text-on-surface-variant" data-i18n="feature1Desc">{t.feature1Desc}</p>
            <ul class="mb-8 space-y-3">
              <li class="flex items-center gap-2 font-semibold">
                <Icon class="size-5 text-secondary dark:text-accent" name="check" />
                <span data-i18n="feature1Highlight1">{t.feature1Highlight1}</span>
              </li>
              <li class="flex items-center gap-2 font-semibold">
                <Icon class="size-5 text-secondary dark:text-accent" name="check" />
                <span data-i18n="feature1Highlight2">{t.feature1Highlight2}</span>
              </li>
            </ul>
          </div>

          <div class="w-full min-w-0 flex-1 transition-transform duration-500 group-hover:scale-[1.03]">
            <Image
              alt="Disponibilidad de estaciones en tiempo real en BiciRadar"
              class="w-full rounded-2xl object-contain shadow-2xl dark:brightness-75"
              decoding="async"
              format="webp"
              loading="lazy"
              quality={76}
              sizes="(min-width: 768px) 42vw, 92vw"
              src={featureAvailabilityImage}
              widths={[420, 640, 820, 1080]}
            />
          </div>
        </article>

        <article class="group flex h-full flex-col justify-between rounded-3xl bg-surface-container-high p-8 dark:border dark:border-white/5 md:col-span-4">
          <div class="mb-8">
            <div class="mb-6 flex size-14 items-center justify-center rounded-2xl bg-white shadow-sm dark:border dark:border-white/10 dark:bg-background">
              <Icon class="size-7 text-primary" name="star" />
            </div>
            <h3 class="font-headline mb-4 text-2xl font-bold" data-i18n="feature2Title">{t.feature2Title}</h3>
            <p class="text-on-surface-variant" data-i18n="feature2Desc">{t.feature2Desc}</p>
          </div>

          <Image
            alt="Estaciones favoritas en la app BiciRadar"
            class="h-40 w-full rounded-xl object-cover transition-opacity group-hover:opacity-90 dark:brightness-75"
            decoding="async"
            format="webp"
            loading="lazy"
            quality={72}
            sizes="(min-width: 768px) 28vw, 92vw"
            src={featureFavoritesImage}
            widths={[320, 480, 720]}
          />
        </article>

        <article class="group relative flex flex-col justify-between overflow-hidden rounded-3xl bg-primary p-8 text-on-primary md:col-span-4">
          <div class="absolute right-0 top-0 p-8 opacity-10 dark:opacity-20">
            <Icon class="size-24" name="bell" />
          </div>
          <div class="relative z-10">
            <h3 class="font-headline mb-4 text-2xl font-bold" data-i18n="feature3Title">{t.feature3Title}</h3>
            <p class="opacity-80" data-i18n="feature3Desc">{t.feature3Desc}</p>
          </div>

          <div class="mt-12 rounded-xl border border-white/20 bg-black/50 p-4 backdrop-blur-md">
            <div class="mb-2 flex items-center justify-between">
              <span class="font-bold" data-i18n="feature3Label">{t.feature3Label}</span>
              <span class="font-black">200<span data-i18n="feature3Distance">{t.feature3Distance}</span></span>
            </div>
            <div class="h-1.5 w-full rounded-full bg-white/20">
              <div class="h-full w-4/5 rounded-full bg-secondary-container dark:bg-accent dark:shadow-[0_0_10px_rgba(127,255,0,0.5)]"></div>
            </div>
          </div>
        </article>

        <article class="group flex flex-col gap-12 rounded-3xl bg-surface-container-low p-8 dark:border dark:border-white/5 md:col-span-8 md:flex-row md:items-center md:p-12">
          <div class="order-2 w-full min-w-0 flex-1 md:order-1">
            <Image
              alt="Widgets y reloj con datos de estaciones en BiciRadar"
              class="w-full rounded-2xl object-contain shadow-xl transition-transform group-hover:rotate-1 dark:brightness-90 dark:grayscale-[0.2]"
              decoding="async"
              format="webp"
              loading="lazy"
              quality={76}
              sizes="(min-width: 768px) 42vw, 92vw"
              src={featureWidgetsImage}
              widths={[420, 640, 820, 1080]}
            />
          </div>

          <div class="order-1 min-w-0 flex-1 md:order-2">
            <h3 class="font-headline mb-6 text-3xl font-bold" data-i18n="feature4Title">{t.feature4Title}</h3>
            <p class="mb-6 text-on-surface-variant" data-i18n="feature4Desc">{t.feature4Desc}</p>
            <div class="flex flex-wrap gap-2">
              <span class="rounded-full bg-secondary-container px-4 py-2 text-xs font-bold uppercase tracking-widest text-on-secondary-container dark:bg-secondary dark:text-white" data-i18n="feature4Tag1">
                {t.feature4Tag1}
              </span>
              <span class="rounded-full bg-surface-container-highest px-4 py-2 text-xs font-bold uppercase tracking-widest text-on-surface dark:bg-surface-container-highest dark:text-on-surface" data-i18n="feature4Tag2">
                {t.feature4Tag2}
              </span>
              <span class="rounded-full bg-surface-container-highest px-4 py-2 text-xs font-bold uppercase tracking-widest text-on-surface dark:bg-surface-container-highest dark:text-on-surface" data-i18n="feature4Tag3">
                {t.feature4Tag3}
              </span>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section class="relative overflow-hidden bg-surface py-24 text-on-surface" id="cities">
      <div class="relative z-10 mx-auto max-w-7xl px-6 md:px-8">
        <div class="grid items-center gap-16 lg:grid-cols-2">
          <div>
            <div class="mb-6 inline-flex items-center gap-2 font-bold text-primary">
              <Icon class="size-5" name="database" />
              <span class="text-sm uppercase tracking-widest" data-i18n="openDataEngine">{t.openDataEngine}</span>
            </div>
            <h2 class="font-headline mb-8 text-4xl font-bold leading-tight lg:text-6xl" data-i18n="basedOnGBFS">
              {t.basedOnGBFS}
            </h2>
            <p class="mb-10 text-lg leading-relaxed text-on-surface-variant" data-i18n="gbfsDescription">
              {t.gbfsDescription}
            </p>
            <div class="grid grid-cols-2 gap-6">
              <div class="rounded-2xl bg-white p-6 shadow-sm dark:border dark:border-white/5 dark:bg-surface-container">
                <p class="font-headline mb-1 text-3xl font-black text-primary">99.9%</p>
                <p class="text-sm font-bold uppercase tracking-tighter opacity-60" data-i18n="uptime">{t.uptime}</p>
              </div>
              <div class="rounded-2xl bg-white p-6 shadow-sm dark:border dark:border-white/5 dark:bg-surface-container">
                <p class="font-headline mb-1 text-3xl font-black text-primary">15s</p>
                <p class="text-sm font-bold uppercase tracking-tighter opacity-60" data-i18n="refreshRate">{t.refreshRate}</p>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            {cities.map((city, index) => (
              <article class:list={[
                'group rounded-3xl border bg-surface-container-lowest p-8 transition-all duration-300 dark:border-white/5 dark:bg-surface-container-lowest dark:hover:bg-primary',
                index % 2 === 1 && 'mt-8',
              ]}>
                <h3 class="font-headline mb-2 text-2xl font-bold" data-city-name={index}>{city.name}</h3>
                <p class="mb-4 font-bold text-on-surface-variant group-hover:text-on-secondary-container dark:group-hover:text-white" data-city-service={index}>
                  {city.service}
                </p>
                <Icon class="size-10 opacity-20 transition-opacity group-hover:opacity-100 dark:text-accent" name="pin" />
              </article>
            ))}

            <article class="rounded-3xl border bg-surface-container-lowest p-8 dark:border-white/5 dark:bg-surface-container-lowest">
              <h3 class="font-headline mb-2 text-2xl font-bold" data-i18n="manyMoreCities">{t.manyMoreCities}</h3>
              <p class="mb-4 font-bold text-on-surface-variant">GBFS</p>
              <Icon class="size-10 opacity-30" name="globe" />
            </article>
          </div>
        </div>
      </div>

      <div class="pointer-events-none absolute right-0 top-0 hidden h-full w-1/2 -mr-20 opacity-[0.04] lg:block dark:opacity-[0.03]">
        <Image
          alt=""
          aria-hidden="true"
          class="h-full w-full object-cover dark:invert"
          decoding="async"
          format="webp"
          loading="lazy"
          quality={52}
          sizes="50vw"
          src={mapBackgroundImage}
          widths={[640, 960, 1280]}
        />
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-24 md:px-8" id="faqs">
      <div class="mb-12">
        <h2 class="font-headline mb-4 text-4xl font-bold tracking-tight lg:text-5xl" data-i18n="faqTitle">
          {t.faqTitle}
        </h2>
        <p class="max-w-3xl text-on-surface-variant" data-i18n="faqSubtitle">
          {t.faqSubtitle}
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {faqItems.map((item, index) => (
          <article class="rounded-3xl border border-outline-variant/20 bg-surface-container-low p-8 dark:border-white/10 dark:bg-surface-container">
            <h3 class="font-headline mb-3 text-xl font-bold" data-faq-question={index}>{item.question}</h3>
            <p class="leading-relaxed text-on-surface-variant" data-faq-answer={index}>{item.answer}</p>
          </article>
        ))}
      </div>

      <div class="mt-10">
        <a
          class="inline-flex items-center gap-2 rounded-xl bg-primary px-6 py-3 font-bold text-on-primary transition-all hover:shadow-lg hover:shadow-primary/20"
          href={seoPagePath}
        >
          <span data-seo-cta>{seoPageCtaByLanguage[lang]}</span>
          <Icon class="size-5" name="arrow-right" />
        </a>
      </div>
    </section>
  </main>

  <footer class="w-full border-t border-slate-200 bg-slate-50 py-8 text-sm dark:border-white/5 dark:bg-[#080808]" id="contact">
    <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-6 px-6 md:px-8">
      <div class="flex items-center gap-6">
        <div class="flex flex-col gap-1">
          <span class="font-headline text-lg font-bold text-slate-900 dark:text-primary">BiciRadar</span>
          <span class="text-xs text-slate-500 dark:text-on-surface-variant">© {currentYear} <span data-i18n="copyright">{t.copyright}</span></span>
        </div>
      </div>

      <div class="flex items-center gap-6">
        <div class="flex flex-wrap gap-2" role="group" aria-label="Idioma de la interfaz">
          {Object.entries(languageNames).map(([code, label]) => (
            <button
              class="lang-button"
              data-active={code === lang ? 'true' : 'false'}
              data-lang-button={code}
              type="button"
            >
              {label}
            </button>
          ))}
        </div>
      </div>

      <div class="flex items-center gap-4">
        <a class="text-xs text-slate-500 transition-colors hover:text-primary hover:underline dark:text-on-surface-variant dark:hover:text-primary" href="#faqs" data-i18n="legal">
          {t.legal}
        </a>
        <a class="text-xs text-slate-500 transition-colors hover:text-primary hover:underline dark:text-on-surface-variant dark:hover:text-primary" href="#contact" data-i18n="contact">
          {t.contact}
        </a>
      </div>
    </div>
  </footer>

  <script id="landing-runtime-data" type="application/json" set:html={JSON.stringify(landingRuntime)}></script>
  <script is:inline>
    (() => {
      const root = document.querySelector('[data-landing-root]');
      const payload = document.getElementById('landing-runtime-data');
      if (!root || !(payload instanceof HTMLScriptElement)) return;

      const data = JSON.parse(payload.textContent || '{}');
      const langStorageKey = 'landing-lang';
      const themeStorageKey = 'theme';
      let currentLang = data.defaultLanguage || 'ES';

      const setButtonState = (lang) => {
        root.querySelectorAll('[data-lang-button]').forEach((button) => {
          button.dataset.active = button.dataset.langButton === lang ? 'true' : 'false';
          button.setAttribute('aria-pressed', button.dataset.active);
        });
      };

      const applyLanguage = (lang) => {
        const copy = data.translations?.[lang];
        if (!copy) return;

        currentLang = lang;
        document.documentElement.lang = data.languageHtmlLang?.[lang] || 'es';

        root.querySelectorAll('[data-i18n]').forEach((node) => {
          const key = node.dataset.i18n;
          if (key && copy[key]) {
            node.textContent = copy[key];
          }
        });

        const cities = data.citiesByLanguage?.[lang] || [];
        root.querySelectorAll('[data-city-name]').forEach((node) => {
          const item = cities[Number(node.dataset.cityName)];
          if (item) node.textContent = item.name;
        });
        root.querySelectorAll('[data-city-service]').forEach((node) => {
          const item = cities[Number(node.dataset.cityService)];
          if (item) node.textContent = item.service;
        });

        const faqs = data.faqByLanguage?.[lang] || [];
        root.querySelectorAll('[data-faq-question]').forEach((node) => {
          const item = faqs[Number(node.dataset.faqQuestion)];
          if (item) node.textContent = item.question;
        });
        root.querySelectorAll('[data-faq-answer]').forEach((node) => {
          const item = faqs[Number(node.dataset.faqAnswer)];
          if (item) node.textContent = item.answer;
        });

        const seoCta = root.querySelector('[data-seo-cta]');
        if (seoCta && data.seoPageCtaByLanguage?.[lang]) {
          seoCta.textContent = data.seoPageCtaByLanguage[lang];
        }

        setButtonState(lang);
        try {
          localStorage.setItem(langStorageKey, lang);
        } catch {}
      };

      root.querySelectorAll('[data-lang-button]').forEach((button) => {
        button.addEventListener('click', () => applyLanguage(button.dataset.langButton || data.defaultLanguage || 'ES'));
      });

      const themeToggle = root.querySelector('[data-theme-toggle]');
      themeToggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        try {
          localStorage.setItem(themeStorageKey, isDark ? 'dark' : 'light');
        } catch {}
      });

      root.querySelectorAll('[data-track-store]').forEach((link) => {
        link.addEventListener('click', () => {
          window.umami?.track('download_click', {
            store: link.dataset.trackStore || '',
            lang: currentLang,
          });
        });
      });

      let savedLang = '';
      try {
        savedLang = localStorage.getItem(langStorageKey) || '';
      } catch {}
      applyLanguage(savedLang || data.defaultLanguage || 'ES');
    })();
  </script>
</div>

---
import Layout from '../../layouts/Layout.astro';
import CityPage from '../../components/marketing/CityPage.astro';
import ThankYouPage from '../../components/marketing/ThankYouPage.astro';
import { getLocaleContent, locales, orderedCityKeys, type Locale } from '../../content/marketing';
import { buildAlternateLinks } from '../../lib/seo';
import { getLanguageSwitchLinks, getLocalizedCityLinks } from '../../lib/marketing-pages';
import { cityDefinitions } from '../../content/marketing/cities';
import type { FaqItemContent } from '../../content/marketing/types';
import { defaultLocale } from '../../lib/i18n';
import { getHomePath, getLocalizedStaticSlug, getThankYouPath, resolveRouteContext } from '../../lib/routes';
import { resolveSiteUrl } from '../../utils/site';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .flatMap((locale) => [
      {
        params: { locale, slug: getLocalizedStaticSlug(locale, 'thankYou') },
        props: { locale, slug: getLocalizedStaticSlug(locale, 'thankYou') },
      },
      ...orderedCityKeys.map((cityKey) => ({
        params: { locale, slug: cityDefinitions[cityKey].slug },
        props: { locale, slug: cityDefinitions[cityKey].slug },
      })),
    ]);
}

const { locale, slug } = Astro.props as { locale: Locale; slug: string };
const route = resolveRouteContext(locale, slug);

if (!route) {
  throw new Error(`Unknown localized route for "${locale}/${slug}"`);
}

const content = getLocaleContent(locale);
const site = resolveSiteUrl(Astro.site);
const alternates = buildAlternateLinks(route, site, import.meta.env.BASE_URL);
const homeHref = getHomePath(locale);
const cityKey = route.kind === 'city' ? route.cityKey : null;
const betaHref = cityKey ? '#beta-form' : `${homeHref}#beta-form`;
const thankYouPath = getThankYouPath(locale);
const formPagePath = `/${locale}/${slug}/`;
const cityLinks = getLocalizedCityLinks(locale);

const pageContent =
  cityKey ? content.cityPages[cityKey] : content.thankYou;

const structuredData =
  cityKey
    ? [
        {
          '@context': 'https://schema.org',
          '@type': 'WebPage',
          name: pageContent.seo.title,
          description: pageContent.seo.description,
          inLanguage: locale,
        },
        {
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: content.cityPages[cityKey].faq.map((item: FaqItemContent) => ({
            '@type': 'Question',
            name: item.question,
            acceptedAnswer: { '@type': 'Answer', text: item.answer },
          })),
        },
      ]
    : [
        {
          '@context': 'https://schema.org',
          '@type': 'WebPage',
          name: content.thankYou.seo.title,
          description: content.thankYou.seo.description,
          inLanguage: locale,
        },
      ];
---

<Layout
  title={pageContent.seo.title}
  description={pageContent.seo.description}
  lang={locale}
  canonicalPath={`/${locale}/${slug}/`}
  alternates={alternates}
  skipLinkLabel={content.common.skipToContent}
  robots={route.kind === 'thank-you' ? 'noindex,follow' : 'index,follow'}
  structuredData={structuredData}
>
  {cityKey ? (
    <CityPage
      content={content}
      cityKey={cityKey}
      languageLinks={getLanguageSwitchLinks(route)}
      homeHref={homeHref}
      betaHref={betaHref}
      thankYouPath={thankYouPath}
      formPagePath={formPagePath}
    />
  ) : (
    <ThankYouPage
      content={content}
      languageLinks={getLanguageSwitchLinks(route)}
      homeHref={homeHref}
      betaHref={betaHref}
      cityLinks={cityLinks}
    />
  )}
</Layout>

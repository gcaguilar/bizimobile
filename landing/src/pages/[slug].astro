---
import Layout from '../layouts/Layout.astro';
import CityPage from '../components/marketing/CityPage.astro';
import { getLocaleContent, orderedCityKeys } from '../content/marketing';
import { buildAlternateLinks } from '../lib/seo';
import { getLanguageSwitchLinks } from '../lib/marketing-pages';
import { cityDefinitions } from '../content/marketing/cities';
import type { FaqItemContent } from '../content/marketing/types';
import { getHomePath, resolveRouteContext } from '../lib/routes';
import { getCityPageMessaging } from '../lib/city-page-messaging';
import { resolveSiteUrl } from '../utils/site';

export function getStaticPaths() {
  return orderedCityKeys.map((cityKey) => ({
    params: { slug: cityDefinitions[cityKey].slug },
    props: { slug: cityDefinitions[cityKey].slug },
  }));
}

const locale = 'es';
const { slug } = Astro.props as { slug: string };
const route = resolveRouteContext(locale, slug);

if (!route || route.kind !== 'city') {
  throw new Error(`Unknown route for slug "${slug}"`);
}

const content = getLocaleContent(locale);
const site = resolveSiteUrl(Astro.site);
const alternates = buildAlternateLinks(route, site, import.meta.env.BASE_URL);
const homeHref = getHomePath(locale);
const cityKey = route.cityKey;
const betaHref = '#beta-form';

const pageContent = content.cityPages[cityKey];
const cityMessaging = getCityPageMessaging(locale, cityKey, pageContent);
const pageTitle = `${cityMessaging.seoTitle} | ${content.common.citySeoTitleSuffix}`;
const pageDescription = `${cityMessaging.seoDescription} ${content.common.citySeoDescriptionSuffix}`;

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: pageTitle,
    description: pageDescription,
    inLanguage: locale,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: content.cityPages[cityKey].faq.map((item: FaqItemContent) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.answer },
    })),
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  lang={locale}
  canonicalPath={`/${slug}/`}
  alternates={alternates}
  skipLinkLabel={content.common.skipToContent}
  robots="index,follow"
  structuredData={structuredData}
>
  <CityPage
    content={content}
    cityKey={cityKey}
    languageLinks={getLanguageSwitchLinks(route)}
    homeHref={homeHref}
    betaHref={betaHref}
  />
</Layout>

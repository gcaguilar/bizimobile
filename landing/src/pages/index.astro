---
import Layout from '../layouts/Layout.astro';
import HomePage from '../components/marketing/HomePage.astro';
import { getLocaleContent } from '../content/marketing';
import { buildAlternateLinks } from '../lib/seo';
import { getLanguageSwitchLinks, getLocalizedCityLinks } from '../lib/marketing-pages';
import { getThankYouPath } from '../lib/routes';
import { resolveSiteUrl } from '../utils/site';

const locale = 'es';
const content = getLocaleContent(locale);
const route = { kind: 'home', locale } as const;
const site = resolveSiteUrl(Astro.site);
const alternates = buildAlternateLinks(route, site, import.meta.env.BASE_URL);
const cityLinks = getLocalizedCityLinks(locale);
const thankYouPath = getThankYouPath(locale);

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: content.metadata.siteName,
    url: new URL('/', site).toString(),
    inLanguage: locale,
    description: content.home.seo.description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: content.home.faq.items.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
];
---

<Layout
  title={content.home.seo.title}
  description={content.home.seo.description}
  lang={locale}
  canonicalPath="/"
  alternates={alternates}
  skipLinkLabel={content.common.skipToContent}
  structuredData={structuredData}
>
  <HomePage
    content={content}
    languageLinks={getLanguageSwitchLinks(route)}
    homeHref="/"
    thankYouPath={thankYouPath}
    cityLinks={cityLinks}
  />
</Layout>

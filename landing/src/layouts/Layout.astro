---
import '../styles/global.css';
import { absolutePageUrl, absoluteUrl, resolveSiteUrl } from '../utils/site';
import type { AlternateLink } from '../lib/seo';
import { localeToOgLocale } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: keyof typeof localeToOgLocale;
  canonicalPath?: string;
  alternates?: AlternateLink[];
  skipLinkLabel?: string;
  robots?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = 'Consulta en tiempo real la disponibilidad de bicis y huecos con BiciRadar.',
  image = '/og-image.svg',
  lang = 'es',
  canonicalPath,
  alternates = [],
  skipLinkLabel = 'Skip to content',
  robots = 'index,follow',
  structuredData = [],
} = Astro.props;

const site = resolveSiteUrl(Astro.site);
const canonical = absolutePageUrl(canonicalPath || Astro.url.pathname, site, import.meta.env.BASE_URL);
const ogImage = absoluteUrl(image, site, import.meta.env.BASE_URL);
const faviconPath = absoluteUrl('/favicon.svg', site, import.meta.env.BASE_URL);
const structuredDataEntries = (Array.isArray(structuredData) ? structuredData : [structuredData]).filter(Boolean);
const ogLocale = localeToOgLocale[lang] || localeToOgLocale.es;
const alternateOgLocales = alternates
  .map((alternate) => alternate.hreflang)
  .filter((hreflang) => hreflang !== lang && hreflang !== 'x-default')
  .map((hreflang) => localeToOgLocale[hreflang as keyof typeof localeToOgLocale])
  .filter(Boolean);
const fontStylesheetHref =
  'https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f8fafc" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />
    ))}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BiciRadar" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />
    {alternateOgLocales.map((locale) => <meta property="og:locale:alternate" content={locale} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href={faviconPath} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href={fontStylesheetHref} as="style" />
    <link rel="stylesheet" href={fontStylesheetHref} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={fontStylesheetHref} /></noscript>
    <script is:inline>
      (() => {
        const loadAnalytics = () => {
          if (document.querySelector('script[data-website-id="f6f1d487-ffc6-43d8-a627-fb6c43c601e4"]')) {
            return;
          }

          const script = document.createElement('script');
          script.src = 'https://cloud.umami.is/script.js';
          script.defer = true;
          script.setAttribute('data-website-id', 'f6f1d487-ffc6-43d8-a627-fb6c43c601e4');
          document.head.append(script);
        };

        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(loadAnalytics, { timeout: 2500 });
        } else {
          window.addEventListener('load', () => window.setTimeout(loadAnalytics, 1), { once: true });
        }
      })();
    </script>
    {structuredDataEntries.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
  </head>
  <body>
    <a class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:rounded-full focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-slate-950" href="#main-content">
      {skipLinkLabel}
    </a>
    <slot />
  </body>
</html>

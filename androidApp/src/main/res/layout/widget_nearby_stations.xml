<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_nearby_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F8FF"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_nearby_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cerca de ti"
        android:textColor="#0D1B2A"
        android:textSize="15sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/widget_row_one"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_row_one_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#0D1B2A"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_row_one_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#5C6B8A"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_row_two"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_row_two_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#0D1B2A"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_row_two_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#5C6B8A"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_row_three"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_row_three_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#0D1B2A"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_row_three_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#5C6B8A"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_nearby_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="#5C6B8A"
        android:textSize="12sp" />
</LinearLayout>

#!/usr/bin/env bash
# post-commit hook — bumps version strings then amends the commit in place.
# Installed by scripts/install_git_hooks.sh

set -euo pipefail

# Prevent re-entry when this hook amends the commit.
[[ "${GIT_NO_POST_COMMIT:-}" == "1" ]] && exit 0

REPO_ROOT="$(git rev-parse --show-toplevel)"
BUMP_SCRIPT="${REPO_ROOT}/scripts/bump_version.sh"

[[ -x "$BUMP_SCRIPT" ]] || { echo "bump_version.sh not found or not executable, skipping."; exit 0; }

"$BUMP_SCRIPT"

# Stage only the version files that may have changed.
git add \
  "${REPO_ROOT}/apple/project.yml" \
  "${REPO_ROOT}/androidApp/build.gradle.kts" \
  "${REPO_ROOT}/wearApp/build.gradle.kts" \
  2>/dev/null || true

# If nothing was actually modified, nothing to amend.
if git diff --cached --quiet; then
  exit 0
fi

# Amend the commit silently, re-using the existing message and author.
# GIT_NO_POST_COMMIT prevents this amend from triggering the hook again.
GIT_NO_POST_COMMIT=1 git commit --amend --no-edit --no-verify
